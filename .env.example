# Kopieren nach .env und Werte anpassen.
# .env wird nicht committet (siehe .gitignore).

# --- PostgreSQL ---
POSTGRES_USER=saaserp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=saaserp
POSTGRES_PORT=5432

# --- Backend (Dart Frog) ---
BACKEND_PORT=8080
JWT_SECRET=change-me-to-a-long-random-string
# Origin der App-User-Web-App, für CORS. "*" nur für lokale Entwicklung.
CORS_ORIGIN=*
# Master-Key zum Wrapping der Tenant-Datenschlüssel (Envelope-Encryption).
ENCRYPTION_MASTER_KEY=change-me-to-a-long-random-string
# Basis-URL der Kunden-App (app_kunde), für Einladungslinks an Endkunden.
APP_KUNDE_URL=http://localhost:8082
# SMTP-Konfiguration für E-Mail-Benachrichtigungen (neues Angebot/neue
# Rechnung/Status-Änderung). SMTP_HOST leer lassen, um den Versand zu
# deaktivieren (es wird dann nur geloggt, z. B. lokale Entwicklung).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@saaserp.local
# "true" für direktes SSL/TLS (Port 465), sonst STARTTLS/Klartext.
SMTP_USE_SSL=false

# --- App-User (Flutter Web) ---
APP_USER_PORT=8081
# URL, unter der die App-User-Web-App das Backend erreicht (Browser-seitig).
API_BASE_URL=http://localhost:8080

# --- App-Kunde (Flutter Web, Kundenportal) ---
APP_KUNDE_PORT=8082

# E-Mail-Adresse, an die Support-Anfragen (POST /api/support/contact) weitergeleitet werden.
# Leer lassen, um Anfragen nur zu loggen (lokal/Test).
SUPPORT_EMAIL=

# --- Backup ---
# Aufbewahrungsdauer für automatische Datenbank-Backups in Tagen.
# Ausführung: docker-compose --profile backup run --rm backup
# Cron-Beispiel (täglich 03:00): 0 3 * * * cd /path/to/saasERP && docker-compose --profile backup run --rm backup
BACKUP_RETENTION_DAYS=30
