# Kopieren nach .env und Werte anpassen.
# .env wird nicht committet (siehe .gitignore).

# --- PostgreSQL ---
POSTGRES_USER=saaserp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=saaserp
POSTGRES_PORT=5432

# --- Backend (Dart Frog) ---
BACKEND_PORT=8080
JWT_SECRET=change-me-to-a-long-random-string
# Origin der App-User-Web-App, für CORS. "*" nur für lokale Entwicklung.
CORS_ORIGIN=*
# Master-Key zum Wrapping der Tenant-Datenschlüssel (Envelope-Encryption).
ENCRYPTION_MASTER_KEY=change-me-to-a-long-random-string
# Basis-URL der Kunden-App (app_kunde), für Einladungslinks an Endkunden.
APP_KUNDE_URL=http://localhost:8082

# --- App-User (Flutter Web) ---
APP_USER_PORT=8081
# URL, unter der die App-User-Web-App das Backend erreicht (Browser-seitig).
API_BASE_URL=http://localhost:8080

# --- App-Kunde (Flutter Web, Kundenportal) ---
APP_KUNDE_PORT=8082
